{
  "name": "sentinel-x",
  "version": "3.2.0",
  "description": "Local-first secret scanner. Finds leaked secrets, maps their propagation, and surgically rewrites git history to purge them.",
  "bin": {
    "sentinel": "./dist/cli.js"
  },
  "files": [
    "dist",
    ".next/standalone",
    ".next/static",
    "public",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "eslint",
    "prepare": "husky install",
    "db:reset": "rm -f sentinel.db sentinel.db-* && bun x drizzle-kit push",
    "cli:build": "bun build src/cli.ts --outfile dist/cli.js --target bun",
    "publish:ready": "bun run build && bun run cli:build && node scripts/copy-standalone.cjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "marked": "^18.0.0",
    "next": "16.2.2",
    "open": "^11.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "simple-git": "^3.35.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
